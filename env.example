# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file — only this template.

# Postgres connection details (read by database.py via os.getenv)
DB_USER=your_db_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbw_project

# Optional: if set, this overrides all of the above and is used as-is
# DATABASE_URL=postgresql://user:password@localhost:5432/dbw_project
